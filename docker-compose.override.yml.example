services:

  # NVIDIA GPU metrics — dev machine only, requires nvidia runtime
  # Not deployed to N150 (no NVIDIA GPU)
  nvidia-gpu-exporter:
    image: utkuozdemir/nvidia_gpu_exporter:1.2.0
    container_name: nvidia-gpu-exporter
    runtime: nvidia
    environment:
      - NVIDIA_VISIBLE_DEVICES=all
    ports:
      - "9835:9835"
    restart: unless-stopped
    profiles: ["monitoring"]
